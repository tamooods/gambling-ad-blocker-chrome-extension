{
  "manifest_version": 3,
  "name": "Gambling Ad Blocker (บล็อกโฆษณาเว็บพนัน)",
  "version": "1.0.0",
  "description": "ซ่อน/บล็อกโฆษณาเว็บพนันออนไลน์บนหน้าเว็บโดยอัตโนมัติ",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["hide.css"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Gambling Ad Blocker"
  },
  "icons": {
    "128": "icon.png"
  }
}
